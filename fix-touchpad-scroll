#!/usr/bin/env bash
set -euo pipefail

WSF_VER="0.3.5"
WSF_DEB="wayland-scroll-factor_${WSF_VER}-1_amd64.deb"
EXT_URL="https://extensions.gnome.org/download-extension/touchpad-speed-control@ritesh.shell-extension.zip?version_tag=72233"

echo "==> Installing Wayland Scroll Factor v${WSF_VER}..."
curl -fsSLO "https://github.com/daniel-g-carrasco/wayland-scroll-factor/releases/download/v${WSF_VER}/${WSF_DEB}"
sudo dpkg -i "$WSF_DEB"
rm -f "$WSF_DEB"

echo "==> Configuring scroll factor (0.15 = slower)..."
wsf set 0.15

echo "==> Enabling WSF (requires logout)..."
wsf enable

echo "==> Installing Touchpad Speed Control GNOME extension..."
curl -fsSL -o touchpad-extension.zip "$EXT_URL"
gnome-extensions install --force touchpad-extension.zip 2>/dev/null
rm -f touchpad-extension.zip

echo ""
echo "Done! Log out and back in for everything to take effect."
echo ""
echo "After login, tune per-app scroll speeds via Extension Manager:"
echo "  → enable 'Touchpad Speed Control' → gear icon → set per-app factors"
echo ""
echo "Global speed:  wsf set 0.2   (slower)  /  wsf set 0.5  (faster)"
echo "Check status:  wsf status"
echo "GUI:           wsf-gui"
